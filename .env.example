# ============================================================
#  ENVIRONMENT VARIABLES - salin file ini ke .env dan isi
# ============================================================

# --- MySQL / PlanetScale ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=data_finance

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Kosongkan jika lokal, isi jika pakai Qdrant Cloud
QDRANT_API_KEY=

# --- Groq LLM ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# --- Embedding Model ---
EMBEDDING_MODEL=paraphrase-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Threshold (akan ditentukan ulang secara empiris) ---
THRESHOLD_INTENT=0.50
THRESHOLD_ENTITY=0.55

# --- Qdrant Collection Names ---
COLLECTION_INTENT=data_intent
COLLECTION_ENTITY=dict_user
COLLECTION_TRANSACTIONS=data_finance

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# --- JWT Auth ---
JWT_SECRET_KEY=ganti_dengan_string_acak_panjang_minimal_32_karakter
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
